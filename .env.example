# ===== LiveClick AI — Environment Variables =====
# Copy this file to .env and fill in real values

# --- App ---
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=false
ALLOWED_ORIGINS=https://liveclick.ai,http://localhost:3000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Redis (Railway provides this automatically) ---
REDIS_URL=redis://localhost:6379/0

# --- YooKassa (yukassa.ru) ---
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=test_your-secret-key
YOOKASSA_RETURN_URL=https://liveclick.ai/dashboard/billing

# --- Cloudflare R2 Storage ---
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_KEY=your-r2-access-key
R2_SECRET=your-r2-secret-key
R2_BUCKET=liveclick-stems
R2_PUBLIC_URL=https://pub.liveclick.ai

# --- Modal.com (GPU inference) ---
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# --- Next.js Frontend ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=https://api.liveclick.ai
NEXT_PUBLIC_APP_URL=https://liveclick.ai
